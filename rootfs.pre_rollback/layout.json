{
  "version": "1.0",
  "created": "2025-01-01T00:00:00Z",
  "description": "AURA-AIOSCPU canonical rootfs SD-card partition layout",
  "partition_count": 11,
  "partitions": {
    "boot": {
      "path": "boot/",
      "type": "read-only",
      "description": "Boot loader, kernel entry, initial config",
      "protected": true,
      "required": true
    },
    "system": {
      "path": "system/",
      "type": "read-only",
      "description": "Core OS files, manifests, validated binaries",
      "protected": true,
      "required": true
    },
    "user": {
      "path": "user/",
      "type": "read-write",
      "description": "User data, user-installed packages, preferences",
      "protected": false,
      "required": true
    },
    "overlay": {
      "path": "overlay/",
      "type": "read-write",
      "description": "Runtime overlay — ephemeral changes over system/",
      "protected": false,
      "required": true
    },
    "aura": {
      "path": "aura/",
      "type": "read-write",
      "description": "AURA personality state, memory, model registry",
      "protected": false,
      "required": true
    },
    "services": {
      "path": "services/",
      "type": "read-write",
      "description": "Deployed service descriptors and runtime state",
      "protected": false,
      "required": true
    },
    "var": {
      "path": "var/",
      "type": "read-write",
      "description": "Runtime logs, boot log, override audit, job queue state",
      "protected": false,
      "required": true
    },
    "tmp": {
      "path": "tmp/",
      "type": "read-write",
      "description": "Ephemeral temp files — cleared on boot",
      "protected": false,
      "required": true
    },
    "etc": {
      "path": "etc/",
      "type": "read-write",
      "description": "System configuration files",
      "protected": false,
      "required": true
    },
    "home": {
      "path": "home/",
      "type": "read-write",
      "description": "User home directories",
      "protected": false,
      "required": true
    },
    "mnt": {
      "path": "mnt/",
      "type": "read-write",
      "description": "External mounts — SD card, USB, volumes",
      "protected": false,
      "required": true
    }
  },
  "sd_card": {
    "detection_paths": {
      "android": [
        "/storage/sdcard1/aura-rootfs",
        "/storage/extSdCard/aura-rootfs",
        "/sdcard/aura-rootfs"
      ],
      "linux": [
        "/media/aura-rootfs",
        "/mnt/sdcard/aura-rootfs"
      ],
      "macos": [
        "/Volumes/aura-rootfs"
      ],
      "windows": []
    }
  },
  "modes": {
    "universal": {
      "description": "Guest OS on top of host — no root, bridge only",
      "requires_root": false,
      "writable_partitions": ["user", "overlay", "aura", "var", "tmp", "home"]
    },
    "internal": {
      "description": "Managed prefix on host — respects host boundaries",
      "requires_root": false,
      "writable_partitions": ["user", "overlay", "aura", "var", "tmp", "home", "etc", "services"]
    },
    "hardware": {
      "description": "Projects onto external hardware via auditable adapters",
      "requires_root": false,
      "writable_partitions": ["user", "overlay", "aura", "var", "tmp", "home", "etc", "services", "mnt"]
    }
  }
}
